---
// src/pages/pricing.astro
const packages = [
  {
    tier: "Essentials",
    name: "Owner's Execution System",
    tagline: "No Coding Required",
    description: "Built for business owners who want results without technical overwhelm.",
    price: 97,
    featured: false,
    items: [
      { included: true,  label: "Book 01 — Breaking Free: System Overview" },
      { included: true,  label: "Book 03 — Owner Execution System" },
      { included: true,  label: "Cost Justification PDF" },
      { included: false, label: "Book 02 — Technical Migration System" },
      { included: false, label: "Client Migration Brief PDF" },
      { included: false, label: "Migration Checklist PDF" },
    ],
    // EDIT: Replace with your real PayPal Buy Now link
    paypalUrl: "https://www.paypal.com/cgi-bin/webscr?cmd=_xclick&business=steve@oviera.co&item_name=Owners+Execution+System&amount=97.00&currency_code=USD&return=https://yourdomain.com/download-essentials",
    btnLabel: "Get the Essentials — $97",
    btnStyle: "outline",
  },
  {
    tier: "Full Bundle",
    name: "Breaking Free System",
    tagline: "Complete Package",
    description: "Everything you need to fully execute platform independence from end to end.",
    price: 179,
    featured: true,
    badge: "Most Complete",
    items: [
      { included: true, label: "Book 01 — Breaking Free: System Overview" },
      { included: true, label: "Book 02 — Technical Migration System" },
      { included: true, label: "Book 03 — Owner Execution System" },
      { included: true, label: "Cost Justification PDF" },
      { included: true, label: "Client Migration Brief PDF" },
      { included: true, label: "Migration Checklist PDF" },
    ],
    // EDIT: Replace with your real PayPal Buy Now link
    paypalUrl: "https://www.paypal.com/cgi-bin/webscr?cmd=_xclick&business=steve@oviera.co&item_name=Breaking+Free+Complete+Package&amount=179.00&currency_code=USD&return=https://yourdomain.com/download-complete",
    btnLabel: "Get the Complete Package — $179",
    btnStyle: "solid",
  },
];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Breaking Free System — Choose Your Package</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f0; color: #1a1a1a; min-height: 100vh; padding: 3rem 1rem; }
    .wrap { max-width: 860px; margin: 0 auto; text-align: center; }
    .eyebrow { font-size: 13px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #888; margin-bottom: 1rem; }
    h1 { font-size: 32px; font-weight: 700; line-height: 1.25; margin-bottom: 0.75rem; }
    .sub { font-size: 17px; color: #555; line-height: 1.6; max-width: 580px; margin: 0 auto 3rem; }
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem; }
    @media(max-width: 620px) { .grid { grid-template-columns: 1fr; } }
    .card { background: #fff; border-radius: 16px; border: 1px solid #e5e5e5; padding: 2rem 1.5rem; text-align: left; position: relative; display: flex; flex-direction: column; }
    .card.featured { border: 2px solid #1a1a2e; }
    .badge { position: absolute; top: -14px; left: 50%; transform: translateX(-50%); background: #1a1a2e; color: #fff; font-size: 12px; font-weight: 600; padding: 4px 16px; border-radius: 99px; white-space: nowrap; }
    .tier-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: #888; margin-bottom: 0.5rem; }
    .tier-name { font-size: 20px; font-weight: 700; line-height: 1.25; margin-bottom: 0.2rem; color: #1a1a1a; }
    .tier-tagline { font-size: 15px; font-weight: 600; color: #444; margin-bottom: 0.4rem; }
    .tier-desc { font-size: 14px; color: #888; margin-bottom: 1.25rem; line-height: 1.5; }
    .price-row { display: flex; align-items: baseline; gap: 6px; margin-bottom: 1.5rem; }
    .price { font-size: 40px; font-weight: 700; color: #1a1a1a; }
    .price-note { font-size: 14px; color: #aaa; }
    .divider { border: none; border-top: 1px solid #f0f0f0; margin-bottom: 1.25rem; }
    .includes-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: #aaa; margin-bottom: 0.75rem; }
    .item { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; padding: 5px 0; line-height: 1.4; }
    .item.included { color: #333; }
    .item.excluded { color: #ccc; }
    .icon { width: 18px; height: 18px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; margin-top: 1px; }
    .icon.check { background: #dcfce7; }
    .icon.x { background: #f5f5f5; }
    .spacer { flex: 1; }
    .btn { display: block; width: 100%; text-decoration: none; border-radius: 10px; padding: 1rem; font-size: 16px; font-weight: 600; text-align: center; margin-top: 1.5rem; cursor: pointer; }
    .btn.solid { background: #1a1a2e; color: #fff; border: none; }
    .btn.solid:hover { background: #111122; }
    .btn.outline { background: transparent; color: #1a1a2e; border: 2px solid #1a1a2e; }
    .btn.outline:hover { background: #f5f5f0; }
    .guarantee { text-align: center; font-size: 14px; color: #888; margin-top: 1rem; }
  </style>
</head>
<body>
  <div class="wrap">
    <p class="eyebrow">Choose your package</p>
    <h1>Breaking Free System</h1>
    <p class="sub">Platform independence for business owners — no coding required.</p>

    <div class="grid">
      {packages.map((pkg) => (
        <div class={`card ${pkg.featured ? "featured" : ""}`}>
          {pkg.badge && <div class="badge">{pkg.badge}</div>}
          <p class="tier-label">{pkg.tier}</p>
          <p class="tier-name">{pkg.name}</p>
          <p class="tier-tagline">{pkg.tagline}</p>
          <p class="tier-desc">{pkg.description}</p>
          <div class="price-row">
            <span class="price">${pkg.price}</span>
            <span class="price-note">one-time</span>
          </div>
          <hr class="divider" />
          <p class="includes-label">What's included</p>
          {pkg.items.map((item) => (
            <div class={`item ${item.included ? "included" : "excluded"}`}>
              {item.included ? (
                <div class="icon check">
                  <svg width="10" height="10" viewBox="0 0 10 10"><polyline points="2,5 4,7 8,3" stroke="#16a34a" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
                </div>
              ) : (
                <div class="icon x">
                  <svg width="10" height="10" viewBox="0 0 10 10"><line x1="3" y1="3" x2="7" y2="7" stroke="#ccc" stroke-width="1.5" stroke-linecap="round"/><line x1="7" y1="3" x2="3" y2="7" stroke="#ccc" stroke-width="1.5" stroke-linecap="round"/></svg>
                </div>
              )}
              {item.label}
            </div>
          ))}
          <div class="spacer"></div>
          <a class={`btn ${pkg.btnStyle}`} href={pkg.paypalUrl} target="_blank">{pkg.btnLabel}</a>
        </div>
      ))}
    </div>
    <p class="guarantee">Secure checkout via PayPal &nbsp;·&nbsp; Instant digital download &nbsp;·&nbsp; No refunds on digital products</p>
  </div>
</body>
</html>
