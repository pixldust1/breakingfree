---
// src/pages/download-essentials.astro
// This page is linked from PayPal as the return URL after $97 purchase
const items = [
  "Book 01 — Breaking Free: System Overview",
  "Book 03 — Owner Execution System",
  "Cost Justification PDF",
];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Download — Owner's Execution System</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f0; color: #1a1a1a; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem 1rem; }
    .wrap { max-width: 560px; width: 100%; text-align: center; }
    .badge { display: inline-block; background: #dcfce7; color: #16a34a; font-size: 13px; font-weight: 500; padding: 5px 14px; border-radius: 99px; margin-bottom: 1.5rem; }
    h1 { font-size: 26px; font-weight: 700; line-height: 1.3; margin-bottom: 0.75rem; }
    .sub { font-size: 16px; color: #555; line-height: 1.6; margin-bottom: 2rem; }
    .card { background: #fff; border-radius: 14px; border: 1px solid #e5e5e5; padding: 2rem 1.5rem; margin-bottom: 1.5rem; }
    .icon-wrap { width: 54px; height: 54px; background: #eff6ff; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; }
    .product-name { font-size: 17px; font-weight: 700; margin-bottom: 0.3rem; }
    .product-detail { font-size: 14px; color: #888; margin-bottom: 1.5rem; }
    .includes { background: #f9f9f7; border-radius: 10px; padding: 1rem 1.25rem; margin-bottom: 1.5rem; text-align: left; }
    .includes-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: #999; margin-bottom: 0.6rem; }
    .item { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: #333; padding: 5px 0; line-height: 1.4; }
    .check { width: 18px; height: 18px; background: #dcfce7; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; margin-top: 1px; }
    .download-btn { display: block; width: 100%; background: #1a1a2e; color: #fff; text-decoration: none; border-radius: 10px; padding: 1rem; font-size: 16px; font-weight: 600; text-align: center; margin-bottom: 0.75rem; }
    .download-btn:hover { background: #111122; }
    .note { font-size: 13px; color: #aaa; }
    .footer { font-size: 13px; color: #aaa; border-top: 1px solid #eee; padding-top: 1.5rem; margin-top: 0.5rem; }
    .footer a { color: #3b82f6; text-decoration: none; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="badge">Payment confirmed</div>
    <h1>Your Owner's Execution System is ready</h1>
    <p class="sub">Thank you for your purchase. Click below to download your files immediately.</p>

    <div class="card">
      <div class="icon-wrap">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
      </div>
      <p class="product-name">Owner's Execution System — No Coding Required</p>
      <p class="product-detail">3 files &middot; ZIP archive &middot; Instant download</p>

      <div class="includes">
        <p class="includes-label">What's included in your download</p>
        {items.map((item) => (
          <div class="item">
            <div class="check">
              <svg width="10" height="10" viewBox="0 0 10 10"><polyline points="2,5 4,7 8,3" stroke="#16a34a" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
            </div>
            {item}
          </div>
        ))}
      </div>

      <!-- EDIT: Replace href with your actual ZIP path in /public/downloads/ -->
      <a class="download-btn" href="/downloads/Owners-Execution-System-v1.zip" download>
        Download your system
      </a>
      <p class="note">File downloads automatically — save it somewhere safe.</p>
    </div>

    <div class="footer">
      Questions? Email <a href="mailto:support@yourdomain.com">support@yourdomain.com</a>
    </div>
  </div>
</body>
</html>
